# Copy to config.env and adjust for your host.

NUM_VMS=3
VM_PREFIX=pve0

VM_MEMORY_MB=4096
VM_CORES=2
VM_MACHINE=pc-q35-7.0
VM_ACCEL=kvm
VM_CPU=host,migratable=on
VM_DISPLAY=gtk
VM_NET_DEVICE=virtio-net-pci

DISK_LAYOUT="a1:20G a2:20G b1:40G b2:40G"

USE_TAP_NETWORK=0
BRIDGE_NAME=manzolo-br0
INTERFACE_NAME=
TAP_PREFIX=manzolo-tap
TAP_USER=
DHCP_ON_BRIDGE=0
# Static IP to assign to the host bridge (e.g. 192.168.100.1/24).
# Leave empty to skip — use when AUTOINSTALL_PROFILE=zfs-mirror-static.
BRIDGE_ADDRESS=

PROXMOX_ISO_VERSION=9.1-1
ISO_URL_INDEX=https://download.proxmox.com/iso/
ISO_URL_FALLBACKS="https://de2.cdn.proxmox.com/iso/ https://de.cdn.proxmox.com/iso/ https://enterprise.proxmox.com/iso/"
ALLOW_INSECURE_TLS=0

# Docker image used when proxmox-auto-install-assistant is not installed locally.
# Override only if you need a different base image.
DOCKER_AUTOINSTALL_IMAGE=debian:trixie

# Used only if you prepare automated-install ISOs.
AUTO_HOSTNAME_PREFIX=pvelab
AUTO_DOMAIN=lab.local
AUTO_ROOT_PASSWORD=CHANGEME
AUTO_MAILTO=root@localhost
# zfs-mirror      — DHCP networking (default)
# zfs-mirror-static — static IPs (requires NODE_FIRST_IP etc. below)
AUTOINSTALL_PROFILE=zfs-mirror
CLUSTER_NAME=pvelab
DATA_ZPOOL_NAME=vmdata
DATA_ZPOOL_DEVICES="sdc sdd"
DATA_STORAGE_ID=vmdata
DATA_STORAGE_CONTENT=images,rootdir

# Static node addressing — used only with AUTOINSTALL_PROFILE=zfs-mirror-static.
# Node N gets the last octet of NODE_FIRST_IP incremented by (N-1).
# e.g. 192.168.100.101 → node1=.101, node2=.102, node3=.103
NODE_FIRST_IP=192.168.100.101
NODE_PREFIX_LEN=24
NODE_GATEWAY=192.168.100.1
NODE_DNS=1.1.1.1
