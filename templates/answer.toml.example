# Starter file for `proxmox-auto-install-assistant`.
# The default lab profile assumes ZFS root on a mirror of the first two disks.
# Review against the official Proxmox automated installation docs before use.

[global]
keyboard = "en-us"
country = "it"
fqdn = "{{FQDN}}"
mailto = "{{MAILTO}}"
timezone = "Europe/Rome"
root-password = "{{ROOT_PASSWORD}}"

[network]
source = "from-dhcp"

[disk-setup]
filesystem = "zfs"
zfs.raid = "raid1"
disk-list = ["sda", "sdb"]
