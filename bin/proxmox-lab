#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CONFIG_FILE="${PROXMOX_LAB_CONFIG:-${REPO_ROOT}/config.env}"
EXAMPLE_CONFIG_FILE="${REPO_ROOT}/config.env.example"

ARTIFACTS_DIR="${REPO_ROOT}/artifacts"
ISO_DIR="${ARTIFACTS_DIR}/iso"
DISKS_DIR="${ARTIFACTS_DIR}/disks"
LOGS_DIR="${ARTIFACTS_DIR}/logs"
RUN_DIR="${ARTIFACTS_DIR}/run"
AUTO_DIR="${ARTIFACTS_DIR}/autoinstall"
BOOTSTRAP_DIR="${ARTIFACTS_DIR}/bootstrap"
TEMPLATE_DIR="${REPO_ROOT}/templates"
PROFILE_DIR="${REPO_ROOT}/profiles"

NUM_VMS=3
VM_PREFIX="pve0"
VM_MEMORY_MB=4096
VM_CORES=2
VM_MACHINE="pc-q35-7.0"
VM_ACCEL="kvm"
VM_CPU="host,migratable=on"
VM_DISPLAY="gtk"
VM_NET_DEVICE="virtio-net-pci"
DISK_LAYOUT="a1:20G a2:20G b1:40G b2:40G"
USE_TAP_NETWORK=0
BRIDGE_NAME="manzolo-br0"
INTERFACE_NAME=""
TAP_PREFIX="manzolo-tap"
TAP_USER=""
DHCP_ON_BRIDGE=0
PROXMOX_ISO_VERSION="9.1-1"
ISO_URL_INDEX="https://download.proxmox.com/iso/"
ISO_URL_FALLBACKS="https://de2.cdn.proxmox.com/iso/ https://de.cdn.proxmox.com/iso/ https://enterprise.proxmox.com/iso/"
ALLOW_INSECURE_TLS=0
QEMU_BIN="qemu-system-x86_64"
QEMU_IMG_BIN="qemu-img"
AUTO_HOSTNAME_PREFIX="pvelab"
AUTO_DOMAIN="lab.local"
AUTO_ROOT_PASSWORD="CHANGEME"
AUTO_MAILTO="root@localhost"
AUTOINSTALL_PROFILE="zfs-mirror"
CLUSTER_NAME="pvelab"
DATA_ZPOOL_NAME="vmdata"
DATA_ZPOOL_DEVICES="sdc sdd"
DATA_STORAGE_ID="vmdata"
DATA_STORAGE_CONTENT="images,rootdir"
USE_DOCKER_AUTOINSTALL=0
DOCKER_AUTOINSTALL_IMAGE="debian:trixie"
NODE_FIRST_IP=""
NODE_PREFIX_LEN="24"
NODE_GATEWAY=""
NODE_DNS="1.1.1.1"
BRIDGE_ADDRESS=""

declare -a CONFIG_OVERRIDES=()

log() {
    printf '[proxmox-lab] %s\n' "$*"
}

warn() {
    printf '[proxmox-lab] warning: %s\n' "$*" >&2
}

die() {
    printf '[proxmox-lab] error: %s\n' "$*" >&2
    exit 1
}

usage() {
    cat <<'EOF'
Usage:
  proxmox-lab menu
  proxmox-lab wizard
  proxmox-lab tui
  proxmox-lab init
  proxmox-lab status
  proxmox-lab iso current
  proxmox-lab iso configured-path
  proxmox-lab iso fetch [latest|VERSION|URL]
  proxmox-lab network up|down|status
  proxmox-lab vm create
  proxmox-lab vm install-headless [all|INDEX]
  proxmox-lab vm install-headless-serial [all|INDEX]
  proxmox-lab vm boot [all|INDEX]
  proxmox-lab vm boot-headless [all|INDEX]
  proxmox-lab vm start [all|INDEX]
  proxmox-lab vm start-headless [all|INDEX]
  proxmox-lab vm stop [all|INDEX]
  proxmox-lab vm inspect [all|INDEX]
  proxmox-lab vm serial [INDEX]
  proxmox-lab clean disks|logs|run|all
  proxmox-lab autoinstall scaffold [all|INDEX]
  proxmox-lab autoinstall validate [all|INDEX|ANSWER_FILE]
  proxmox-lab autoinstall prepare-iso SOURCE_ISO [all|INDEX|ANSWER_FILE]
  proxmox-lab cluster scaffold

Global options:
  --config PATH           Use a specific config file.
  --set KEY=VALUE         Override a config value for the current invocation.
  --docker                Force Docker for proxmox-auto-install-assistant (auto-detected when not installed).
EOF
}

ensure_dirs() {
    mkdir -p "${ARTIFACTS_DIR}" "${ISO_DIR}" "${DISKS_DIR}" "${LOGS_DIR}" "${RUN_DIR}" "${AUTO_DIR}" "${BOOTSTRAP_DIR}"
}

load_config() {
    if [[ -f "${CONFIG_FILE}" ]]; then
        # shellcheck disable=SC1090
        source "${CONFIG_FILE}"
    fi

    local assignment key value
    if ((${#CONFIG_OVERRIDES[@]} > 0)); then
        for assignment in "${CONFIG_OVERRIDES[@]}"; do
            key="${assignment%%=*}"
            value="${assignment#*=}"
            printf -v "${key}" '%s' "${value}"
            export "${key}=${value}"
        done
    fi

    [[ -n "${TAP_USER}" ]] || TAP_USER="${SUDO_USER:-${USER:-root}}"
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "this command must run as root"
}

curl_args() {
    local -a args
    args=(-fL --progress-bar)
    if [[ "${ALLOW_INSECURE_TLS}" -eq 1 ]]; then
        warn "TLS certificate verification disabled for curl because ALLOW_INSECURE_TLS=1"
        args+=(-k)
    fi
    printf '%s\n' "${args[@]}"
}

iso_candidate_bases() {
    local base
    printf '%s\n' "${ISO_URL_INDEX}"
    for base in ${ISO_URL_FALLBACKS}; do
        if [[ "${base}" != "${ISO_URL_INDEX}" ]]; then
            printf '%s\n' "${base}"
        fi
    done
}

curl_capture() {
    local output_file="$1"
    shift

    if "$@" >"${output_file}" 2>&1; then
        return 0
    fi
    return 1
}

probe_iso_index() {
    local base_url="$1"
    local output_file="$2"
    local -a args

    mapfile -t args < <(curl_args)
    curl_capture "${output_file}" curl "${args[@]}" -sS "${base_url}"
}

download_iso_file() {
    local url="$1"
    local target="$2"
    local output_file="$3"
    local -a args

    mapfile -t args < <(curl_args)
    curl_capture "${output_file}" curl "${args[@]}" -o "${target}" "${url}"
}

first_repo_iso() {
    find "${REPO_ROOT}" -maxdepth 1 -type f -name 'proxmox-ve_*.iso' | sort | head -n 1
}

vm_name() {
    local index="$1"
    printf '%s%d' "${VM_PREFIX}" "${index}"
}

node_hostname() {
    local index="$1"
    printf '%s%d' "${AUTO_HOSTNAME_PREFIX}" "${index}"
}

node_fqdn() {
    local index="$1"
    printf '%s.%s' "$(node_hostname "${index}")" "${AUTO_DOMAIN}"
}

node_address() {
    local index="$1"
    if [[ -n "${NODE_FIRST_IP}" ]]; then
        local ip_base ip_last
        ip_base="${NODE_FIRST_IP%.*}"
        ip_last="${NODE_FIRST_IP##*.}"
        printf '%s' "${ip_base}.$((ip_last + index - 1))"
    else
        node_fqdn "${index}"
    fi
}

vm_mac() {
    local index="$1"
    printf '52:54:00:ac:11:%02x' "${index}"
}

disk_path() {
    local index="$1"
    local suffix="$2"
    printf '%s/%s%s.qcow2' "${DISKS_DIR}" "$(vm_name "${index}")" "${suffix}"
}

vm_pid_path() {
    local index="$1"
    printf '%s/%s.pid' "${RUN_DIR}" "$(vm_name "${index}")"
}

vm_serial_log_path() {
    local index="$1"
    printf '%s/%s-serial.log' "${LOGS_DIR}" "$(vm_name "${index}")"
}

vm_monitor_path() {
    local index="$1"
    printf '%s/%s.mon' "${RUN_DIR}" "$(vm_name "${index}")"
}

current_iso_path() {
    printf '%s/current.iso' "${ISO_DIR}"
}

configured_iso_path() {
    printf '%s/proxmox-ve_%s.iso' "${ISO_DIR}" "${PROXMOX_ISO_VERSION}"
}

node_answer_path() {
    local index="$1"
    printf '%s/%s-answer.toml' "${AUTO_DIR}" "$(vm_name "${index}")"
}

node_iso_path() {
    local index="$1"
    printf '%s/%s-auto.iso' "${ISO_DIR}" "$(vm_name "${index}")"
}

resolve_vm_iso() {
    local index="$1"
    local node_iso
    node_iso="$(node_iso_path "${index}")"
    if [[ -f "${node_iso}" ]]; then
        printf '%s' "${node_iso}"
        return 0
    fi
    resolve_iso_path
}

resolve_iso_path() {
    local current
    current="$(current_iso_path)"

    if [[ -L "${current}" || -f "${current}" ]]; then
        printf '%s' "${current}"
        return 0
    fi

    if compgen -G "${REPO_ROOT}/proxmox-ve_*.iso" >/dev/null; then
        first_repo_iso
        return 0
    fi

    return 1
}

latest_iso_filename() {
    local html base_url
    local tmp_output
    require_command curl
    tmp_output="$(mktemp)"

    while IFS= read -r base_url; do
        if probe_iso_index "${base_url}" "${tmp_output}"; then
            if [[ "${base_url}" != "${ISO_URL_INDEX}" ]]; then
                warn "using fallback ISO index ${base_url}"
            fi
            html="$(cat "${tmp_output}")"
            rm -f "${tmp_output}"
            printf '%s\n' "${html}" \
                | grep -Eo 'proxmox-ve_[0-9][^"]+\.iso' \
                | sort -V \
                | tail -n 1
            return 0
        fi
        warn "failed ISO index ${base_url}: $(tail -n 1 "${tmp_output}")"
    done < <(iso_candidate_bases)

    rm -f "${tmp_output}"
    die "failed to query any Proxmox ISO index"
}

iso_filename_for_selector() {
    local selector="${1:-latest}"

    if [[ "${selector}" =~ ^https?:// ]]; then
        printf '%s\n' "${selector##*/}"
    elif [[ "${selector}" == "latest" ]]; then
        latest_iso_filename
    elif [[ "${selector}" == "configured" ]]; then
        printf 'proxmox-ve_%s.iso\n' "${PROXMOX_ISO_VERSION}"
    else
        printf 'proxmox-ve_%s.iso\n' "${selector}"
    fi
}

iso_target_path() {
    local selector="${1:-latest}"
    local filename

    filename="$(iso_filename_for_selector "${selector}")"
    [[ -n "${filename}" ]] || die "could not determine target ISO filename"
    printf '%s/%s\n' "${ISO_DIR}" "${filename}"
}

iso_fetch() {
    ensure_dirs

    local selector="${1:-latest}"
    local filename url target base_url
    local tmp_output

    filename="$(iso_filename_for_selector "${selector}")"
    [[ -n "${filename}" ]] || die "could not determine latest Proxmox VE ISO"

    target="${ISO_DIR}/${filename}"
    require_command curl
    tmp_output="$(mktemp)"

    if [[ "${selector}" =~ ^https?:// ]]; then
        log "downloading ${url}"
        if ! download_iso_file "${url}" "${target}" "${tmp_output}"; then
            local last_line
            last_line="$(tail -n 1 "${tmp_output}")"
            rm -f "${tmp_output}"
            die "failed to download ${url}: ${last_line}"
        fi
        rm -f "${tmp_output}"
        ln -sfn "${target}" "$(current_iso_path)"
        log "current ISO -> ${target}"
        return 0
    fi

    while IFS= read -r base_url; do
        url="${base_url%/}/${filename}"
        log "downloading ${url}"
        if download_iso_file "${url}" "${target}" "${tmp_output}"; then
            if [[ "${base_url}" != "${ISO_URL_INDEX}" ]]; then
                warn "download succeeded via fallback ${base_url}"
            fi
            rm -f "${tmp_output}"
            ln -sfn "${target}" "$(current_iso_path)"
            log "current ISO -> ${target}"
            return 0
        fi
        warn "failed download ${url}: $(tail -n 1 "${tmp_output}")"
    done < <(iso_candidate_bases)

    rm -f "${tmp_output}"
    die "failed to download ${filename} from all configured ISO endpoints"
}

iso_current() {
    local iso
    if iso="$(resolve_iso_path)"; then
        printf '%s\n' "${iso}"
    else
        die "no ISO configured or downloaded"
    fi
}

init_workspace() {
    ensure_dirs
    if [[ ! -f "${CONFIG_FILE}" ]]; then
        cp "${EXAMPLE_CONFIG_FILE}" "${CONFIG_FILE}"
        log "created ${CONFIG_FILE}"
    else
        log "config already present: ${CONFIG_FILE}"
    fi
    if [[ ! -e "$(current_iso_path)" ]] && compgen -G "${REPO_ROOT}/proxmox-ve_*.iso" >/dev/null; then
        ln -sfn "$(first_repo_iso)" "$(current_iso_path)"
        log "linked existing ISO to $(current_iso_path)"
    fi
}

status() {
    ensure_dirs
    local iso
    printf 'Config: %s\n' "${CONFIG_FILE}"
    printf 'VMs: %s prefix=%s memory=%sMB cores=%s\n' "${NUM_VMS}" "${VM_PREFIX}" "${VM_MEMORY_MB}" "${VM_CORES}"
    printf 'Disks dir: %s\n' "${DISKS_DIR}"
    printf 'Logs dir: %s\n' "${LOGS_DIR}"
    printf 'Network mode: %s\n' "$([[ "${USE_TAP_NETWORK}" -eq 1 ]] && printf 'tap' || printf 'user')"
    if iso="$(resolve_iso_path 2>/dev/null)"; then
        printf 'ISO: %s\n' "${iso}"
    else
        printf 'ISO: missing\n'
    fi
    printf 'Disk count: '
    find "${DISKS_DIR}" -maxdepth 1 -type f -name '*.qcow2' | wc -l
    printf 'Running pid files: '
    find "${RUN_DIR}" -maxdepth 1 -type f -name '*.pid' | wc -l
}

create_disks() {
    ensure_dirs
    require_command "${QEMU_IMG_BIN}"

    local index layout suffix size path
    for ((index = 1; index <= NUM_VMS; index++)); do
        for layout in ${DISK_LAYOUT}; do
            suffix="${layout%%:*}"
            size="${layout#*:}"
            path="$(disk_path "${index}" "${suffix}")"
            if [[ -f "${path}" ]]; then
                log "skip existing disk ${path}"
            else
                log "create ${path} (${size})"
                "${QEMU_IMG_BIN}" create -f qcow2 -o preallocation=off "${path}" "${size}" >/dev/null
            fi
        done
    done
}

launch_vm_mode() {
    local index="$1"
    local boot_flow="${2:-boot}"
    local mode="${3:-graphical}"
    ensure_dirs
    require_command "${QEMU_BIN}"

    local iso vm pid_file log_file serial_log monitor_path
    local layout suffix netdev_arg device_arg
    local -a qemu_args
    vm="$(vm_name "${index}")"
    pid_file="$(vm_pid_path "${index}")"
    log_file="${LOGS_DIR}/${vm}.log"
    serial_log="$(vm_serial_log_path "${index}")"
    monitor_path="$(vm_monitor_path "${index}")"

    if [[ -f "${pid_file}" ]] && kill -0 "$(cat "${pid_file}")" 2>/dev/null; then
        log "${vm} already running"
        return 0
    fi

    qemu_args=(
        -name "${vm}"
        -machine "${VM_MACHINE},usb=off,vmport=off,dump-guest-core=off"
        -accel "${VM_ACCEL}"
        -cpu "${VM_CPU}"
        -device virtio-scsi-pci
    )

    for layout in ${DISK_LAYOUT}; do
        suffix="${layout%%:*}"
        [[ -f "$(disk_path "${index}" "${suffix}")" ]] || die "missing disk $(disk_path "${index}" "${suffix}"); run 'proxmox-lab vm create'"
        qemu_args+=(
            -drive "file=$(disk_path "${index}" "${suffix}"),if=none,id=drive_${index}_${suffix},format=qcow2"
            -device "scsi-hd,drive=drive_${index}_${suffix}"
        )
    done

    if [[ "${USE_TAP_NETWORK}" -eq 1 ]]; then
        netdev_arg="tap,id=net${index},ifname=${TAP_PREFIX}${index},script=no,downscript=no"
    else
        netdev_arg="user,id=net${index},hostname=${vm}"
    fi
    device_arg="${VM_NET_DEVICE},netdev=net${index},mac=$(vm_mac "${index}")"

    qemu_args+=(
        -m "${VM_MEMORY_MB}"
        -netdev "${netdev_arg}"
        -device "${device_arg}"
        -smp "cores=${VM_CORES}"
    )

    case "${boot_flow}" in
        install)
            iso="$(resolve_vm_iso "${index}")" || die "no ISO available; run 'proxmox-lab iso fetch latest' first"
            qemu_args+=(
                -boot once=d
                -drive "file=${iso},media=cdrom,if=ide,index=0"
                -no-reboot
            )
            ;;
        boot)
            qemu_args+=(
                -boot c
            )
            ;;
        *)
            die "unsupported boot flow: ${boot_flow}"
            ;;
    esac

    if [[ "${mode}" == "headless" ]]; then
        : > "${serial_log}"
        rm -f "${monitor_path}"
        rm -f "${pid_file}"
        qemu_args+=(
            -display none
            -monitor "unix:${monitor_path},server,nowait"
            -serial "file:${serial_log}"
            -daemonize
            -pidfile "${pid_file}"
        )
        if [[ "${boot_flow}" == "boot" ]]; then
            qemu_args+=(-no-shutdown)
        fi
    else
        qemu_args+=(
            -vga std
            -display "${VM_DISPLAY}"
        )
    fi

    log "starting ${vm} (${boot_flow}, ${mode})"
    if [[ "${mode}" == "headless" ]]; then
        "${QEMU_BIN}" "${qemu_args[@]}" >"${log_file}" 2>&1
        local tries=0
        while [[ ! -f "${pid_file}" && "${tries}" -lt 20 ]]; do
            sleep 0.1
            tries=$((tries + 1))
        done
        [[ -f "${pid_file}" ]] || die "missing pid file after daemonized launch: ${pid_file}"
    else
        nohup "${QEMU_BIN}" "${qemu_args[@]}" >"${log_file}" 2>&1 &
        echo $! > "${pid_file}"
    fi

    log "${vm} pid=$(cat "${pid_file}") log=${log_file}"
}

install_vm_headless() {
    launch_vm_mode "$1" install headless
}

boot_vm() {
    launch_vm_mode "$1" boot graphical
}

boot_vm_headless() {
    launch_vm_mode "$1" boot headless
}

start_vm() {
    boot_vm "$1"
}

start_vm_headless() {
    boot_vm_headless "$1"
}

stop_vm() {
    local index="$1"
    local vm pid_file pid
    vm="$(vm_name "${index}")"
    pid_file="$(vm_pid_path "${index}")"

    if [[ ! -f "${pid_file}" ]]; then
        log "no pid file for ${vm}"
        return 0
    fi

    pid="$(cat "${pid_file}")"
    if kill -0 "${pid}" 2>/dev/null; then
        log "stopping ${vm} (${pid})"
        kill "${pid}"
    fi
    rm -f "${pid_file}"
}

inspect_vm() {
    local index="$1"
    local vm pid_file serial_log monitor_path pid

    vm="$(vm_name "${index}")"
    pid_file="$(vm_pid_path "${index}")"
    serial_log="$(vm_serial_log_path "${index}")"
    monitor_path="$(vm_monitor_path "${index}")"

    printf 'VM: %s\n' "${vm}"
    printf 'PID file: %s\n' "${pid_file}"
    if [[ -f "${pid_file}" ]]; then
        pid="$(cat "${pid_file}")"
        printf 'PID: %s\n' "${pid}"
        if kill -0 "${pid}" 2>/dev/null; then
            ps -p "${pid}" -o pid,etime,%cpu,%mem,cmd
        else
            printf 'Process: not running\n'
        fi
    else
        printf 'PID: missing\n'
    fi
    printf 'Main log: %s\n' "${LOGS_DIR}/${vm}.log"
    printf 'Serial log: %s\n' "${serial_log}"
    printf 'Monitor socket: %s\n' "${monitor_path}"
}

serial_vm() {
    local index="$1"
    local serial_log

    serial_log="$(vm_serial_log_path "${index}")"
    [[ -f "${serial_log}" ]] || die "missing serial log: ${serial_log}"
    tail -n 120 "${serial_log}"
}

network_status() {
    if ip link show "${BRIDGE_NAME}" >/dev/null 2>&1; then
        printf 'bridge %s: present\n' "${BRIDGE_NAME}"
    else
        printf 'bridge %s: absent\n' "${BRIDGE_NAME}"
    fi

    local index
    for ((index = 1; index <= NUM_VMS; index++)); do
        if ip link show "${TAP_PREFIX}${index}" >/dev/null 2>&1; then
            printf 'tap %s%s: present\n' "${TAP_PREFIX}" "${index}"
        else
            printf 'tap %s%s: absent\n' "${TAP_PREFIX}" "${index}"
        fi
    done
}

network_up() {
    require_root
    require_command ip
    ensure_dirs

    if ! ip link show "${BRIDGE_NAME}" >/dev/null 2>&1; then
        ip link add name "${BRIDGE_NAME}" type bridge
    fi
    ip link set dev "${BRIDGE_NAME}" up

    if [[ -n "${INTERFACE_NAME}" ]]; then
        ip addr flush dev "${INTERFACE_NAME}" || true
        ip link set dev "${INTERFACE_NAME}" master "${BRIDGE_NAME}"
        ip link set dev "${INTERFACE_NAME}" up
    fi

    if [[ -n "${BRIDGE_ADDRESS}" ]]; then
        ip addr replace "${BRIDGE_ADDRESS}" dev "${BRIDGE_NAME}"
    fi

    local index tap_name
    for ((index = 1; index <= NUM_VMS; index++)); do
        tap_name="${TAP_PREFIX}${index}"
        if ! ip link show "${tap_name}" >/dev/null 2>&1; then
            ip tuntap add dev "${tap_name}" mode tap user "${TAP_USER}"
        fi
        ip link set dev "${tap_name}" master "${BRIDGE_NAME}"
        ip link set dev "${tap_name}" up
    done

    if [[ "${DHCP_ON_BRIDGE}" -eq 1 ]]; then
        require_command dhclient
        dhclient -v "${BRIDGE_NAME}"
    fi
}

network_down() {
    require_root
    require_command ip

    local index tap_name
    for ((index = 1; index <= NUM_VMS; index++)); do
        tap_name="${TAP_PREFIX}${index}"
        ip link set dev "${tap_name}" down 2>/dev/null || true
        ip tuntap del dev "${tap_name}" mode tap 2>/dev/null || true
    done

    if [[ -n "${INTERFACE_NAME}" ]]; then
        ip link set dev "${INTERFACE_NAME}" nomaster 2>/dev/null || true
        ip link set dev "${INTERFACE_NAME}" up 2>/dev/null || true
        if [[ "${DHCP_ON_BRIDGE}" -eq 1 ]] && command -v dhclient >/dev/null 2>&1; then
            dhclient -v "${INTERFACE_NAME}" || true
        fi
    fi

    ip link set dev "${BRIDGE_NAME}" down 2>/dev/null || true
    ip link delete "${BRIDGE_NAME}" type bridge 2>/dev/null || true
}

clean_disks() {
    ensure_dirs
    find "${DISKS_DIR}" -maxdepth 1 -type f -name '*.qcow2' -delete
    log "removed disk artifacts from ${DISKS_DIR}"
}

clean_logs() {
    ensure_dirs
    find "${LOGS_DIR}" -maxdepth 1 -type f -delete
    log "removed logs from ${LOGS_DIR}"
}

clean_run() {
    ensure_dirs
    find "${RUN_DIR}" -maxdepth 1 -type f -delete
    log "removed pid files from ${RUN_DIR}"
}

clean_autoinstall() {
    ensure_dirs
    find "${AUTO_DIR}" -maxdepth 1 -type f -name '*-answer.toml' -delete
    find "${ISO_DIR}" -maxdepth 1 -type f -name '*-auto.iso' -delete
    log "removed autoinstall artifacts from ${AUTO_DIR} and ${ISO_DIR}"
}

clean_all() {
    clean_logs
    clean_run
    clean_disks
    clean_autoinstall
    if [[ "${USE_TAP_NETWORK}" -eq 1 ]]; then
        warn "TAP mode enabled; run 'sudo proxmox-lab network down' if bridge cleanup is also required"
    fi
}

press_enter() {
    read -r -p "Press Enter to continue..." _
}

tui_capture() {
    local output_file="$1"
    shift

    if ( "$@" ) >"${output_file}" 2>&1; then
        return 0
    fi
    return 1
}

tui_run() {
    if ( "$@" ); then
        :
    else
        warn "command failed: $*"
    fi
    press_enter
}

dialog_bin() {
    if command -v dialog >/dev/null 2>&1; then
        printf '%s\n' "dialog"
        return 0
    fi
    if command -v whiptail >/dev/null 2>&1; then
        printf '%s\n' "whiptail"
        return 0
    fi
    return 1
}

dialog_title() {
    printf 'Proxmox Lab'
}

dialog_backtitle() {
    printf 'Config: %s | Mode: %s' "${CONFIG_FILE}" "$([[ "${USE_TAP_NETWORK}" -eq 1 ]] && printf 'tap' || printf 'user')"
}

dialog_show_text() {
    local title="$1"
    local file="$2"
    local ui

    ui="$(dialog_bin)" || return 1
    if [[ "${ui}" == "dialog" ]]; then
        dialog --backtitle "$(dialog_backtitle)" --title "${title}" --textbox "${file}" 22 90
    else
        whiptail --backtitle "$(dialog_backtitle)" --title "${title}" --scrolltext --textbox "${file}" 22 90
    fi
}

dialog_show_infobox() {
    local title="$1"
    local message="$2"
    local ui

    ui="$(dialog_bin)" || return 1
    if [[ "${ui}" == "dialog" ]]; then
        dialog --backtitle "$(dialog_backtitle)" --title "${title}" --infobox "${message}" 10 80
    else
        whiptail --backtitle "$(dialog_backtitle)" --title "${title}" --infobox "${message}" 10 80
    fi
}

dialog_run_message() {
    local title="$1"

    case "${title}" in
        "Fetch Latest ISO"|"Fetch Configured ISO")
            printf 'Resolving ISO source and downloading if needed.\nThis can take a while for large images.\n\nPlease wait...'
            ;;
        "Install All VMs"|"Install All VMs (Headless)")
            printf 'Starting unattended installation.\nThe VMs will exit automatically when the installer tries to reboot.\n\nPlease wait...'
            ;;
        "Boot All VMs"|"Boot All VMs (Headless)")
            printf 'Starting virtual machines.\n\nPlease wait...'
            ;;
        "Network Up"|"Network Down")
            printf 'Updating host network state.\n\nPlease wait...'
            ;;
        "Autoinstall Validate")
            printf 'Validating the Proxmox autoinstall answer file.\n\nPlease wait...'
            ;;
        *)
            printf 'Running command.\n\nPlease wait...'
            ;;
    esac
}

dialog_run() {
    local title="$1"
    shift

    local output_file status_file status
    output_file="$(mktemp)"
    status_file="$(mktemp)"

    if [[ -t 0 && -t 1 ]]; then
        dialog_show_infobox "${title}" "$(dialog_run_message "${title}")" || true
    fi

    if tui_capture "${output_file}" "$@"; then
        printf '0' >"${status_file}"
    else
        printf '%s' "$?" >"${status_file}"
    fi

    status="$(cat "${status_file}")"
    if [[ "${status}" == "0" ]]; then
        printf '[proxmox-lab] command succeeded: %s\n\n' "$*" >>"${output_file}"
    else
        printf '\n[proxmox-lab] command failed (%s): %s\n' "${status}" "$*" >>"${output_file}"
    fi

    dialog_show_text "${title}" "${output_file}" || true
    rm -f "${output_file}" "${status_file}"
}

iso_file_summary() {
    local target="$1"
    local resolved size mtime

    resolved="$(readlink -f "${target}" 2>/dev/null || printf '%s' "${target}")"

    size="$(stat -c '%s' "${resolved}" 2>/dev/null || printf '?')"
    mtime="$(stat -c '%y' "${resolved}" 2>/dev/null | cut -d'.' -f1 || printf '?')"

    if [[ "${resolved}" != "${target}" ]]; then
        printf 'Link: %s\nTarget: %s\nSize: %s bytes\nModified: %s' "${target}" "${resolved}" "${size}" "${mtime}"
    else
        printf 'Path: %s\nSize: %s bytes\nModified: %s' "${resolved}" "${size}" "${mtime}"
    fi
}

confirm_iso_refetch_basic() {
    local target="$1"
    local answer

    printf 'ISO already present:\n%s\n' "$(iso_file_summary "${target}")"
    read -r -p "Re-download it? [y/N] " answer
    [[ "${answer}" =~ ^[Yy]([Ee][Ss])?$ ]]
}

confirm_iso_refetch_dialog() {
    local target="$1"
    local ui

    ui="$(dialog_bin)" || return 1
    if [[ "${ui}" == "dialog" ]]; then
        dialog \
            --defaultno \
            --backtitle "$(dialog_backtitle)" \
            --title "ISO Already Present" \
            --yesno "The ISO is already present:\n\n$(iso_file_summary "${target}")\n\nRe-download it?" 15 80
    else
        whiptail \
            --defaultno \
            --backtitle "$(dialog_backtitle)" \
            --title "ISO Already Present" \
            --yesno "The ISO is already present:\n\n$(iso_file_summary "${target}")\n\nRe-download it?" 15 80
    fi
}

maybe_fetch_iso_basic() {
    local selector="$1"
    local target

    if [[ "${selector}" == "latest" ]] && target="$(resolve_iso_path 2>/dev/null)"; then
        :
    else
        target="$(iso_target_path "${selector}")"
    fi

    if [[ -f "${target}" ]]; then
        if ! confirm_iso_refetch_basic "${target}"; then
            log "keeping existing ISO ${target}"
            press_enter
            return 0
        fi
    fi

    tui_run iso_fetch "${selector}"
}

maybe_fetch_iso_dialog() {
    local selector="$1"
    local title="$2"
    local target

    if [[ "${selector}" == "latest" ]] && target="$(resolve_iso_path 2>/dev/null)"; then
        :
    else
        target="$(iso_target_path "${selector}")"
    fi

    if [[ -f "${target}" ]]; then
        if ! confirm_iso_refetch_dialog "${target}"; then
            return 0
        fi
    fi

    dialog_run "${title}" iso_fetch "${selector}"
}

tui_draw_header() {
    clear
    printf 'Proxmox Lab TUI\n'
    printf '================\n'
    printf 'Config: %s\n' "${CONFIG_FILE}"
    printf 'Mode: %s\n\n' "$([[ "${USE_TAP_NETWORK}" -eq 1 ]] && printf 'tap' || printf 'user')"
}

tui_basic() {
    local choice iso_path

    while true; do
        tui_draw_header
        if iso_path="$(resolve_iso_path 2>/dev/null)"; then
            printf 'ISO: %s\n\n' "${iso_path}"
        else
            printf 'ISO: missing\n\n'
        fi

        cat <<'EOF'
1. Status
2. Init workspace
3. Fetch latest ISO
4. Fetch configured ISO
5. Create disks
6. Install all VMs
7. Boot all VMs
8. Stop all VMs
9. Network up
10. Network down
11. Autoinstall scaffold
12. Autoinstall validate
13. Clean disks
14. Clean all
15. Exit
q. Quit
EOF
        printf '\nSelect: '
        read -r choice

        case "${choice}" in
            1) tui_run status ;;
            2) tui_run init_workspace ;;
            3) maybe_fetch_iso_basic latest ;;
            4) maybe_fetch_iso_basic configured ;;
            5) tui_run create_disks ;;
            6) tui_run install_all_headless ;;
            7) tui_run boot_all ;;
            8) tui_run stop_all ;;
            9) tui_run network_up ;;
            10) tui_run network_down ;;
            11) tui_run autoinstall_scaffold ;;
            12) tui_run autoinstall_validate ;;
            13) tui_run clean_disks ;;
            14) tui_run clean_all ;;
            15) break ;;
            q|Q) break ;;
            *) warn "invalid choice"; press_enter ;;
        esac
    done
}

dialog_menu_loop() {
    local ui choice status iso_path
    ui="$(dialog_bin)" || return 1

    while true; do
        iso_path="$(resolve_iso_path 2>/dev/null || printf 'missing')"

        if [[ "${ui}" == "dialog" ]]; then
            choice="$(
                dialog \
                    --clear \
                    --stdout \
                    --backtitle "$(dialog_backtitle)" \
                    --title "$(dialog_title)" \
                    --menu "ISO: ${iso_path}" 22 90 13 \
                    1 "Status" \
                    2 "Init workspace" \
                    3 "Fetch latest ISO" \
                    4 "Fetch configured ISO" \
                    5 "Create disks" \
                    6 "Install all VMs" \
                    7 "Boot all VMs" \
                    8 "Stop all VMs" \
                    9 "Network up" \
                    10 "Network down" \
                    11 "Autoinstall scaffold" \
                    12 "Autoinstall validate" \
                    13 "Clean disks" \
                    14 "Clean all" \
                    15 "Exit"
            )"
            status="$?"
        else
            choice="$(
                whiptail \
                    --title "$(dialog_title)" \
                    --backtitle "$(dialog_backtitle)" \
                    --menu "ISO: ${iso_path}" 22 90 13 \
                    "1" "Status" \
                    "2" "Init workspace" \
                    "3" "Fetch latest ISO" \
                    "4" "Fetch configured ISO" \
                    "5" "Create disks" \
                    "6" "Install all VMs" \
                    "7" "Boot all VMs" \
                    "8" "Stop all VMs" \
                    "9" "Network up" \
                    "10" "Network down" \
                    "11" "Autoinstall scaffold" \
                    "12" "Autoinstall validate" \
                    "13" "Clean disks" \
                    "14" "Clean all" \
                    "15" "Exit" \
                    3>&1 1>&2 2>&3
            )"
            status="$?"
        fi

        [[ "${status}" -eq 0 ]] || break

        case "${choice}" in
            1) dialog_run "Status" status ;;
            2) dialog_run "Init Workspace" init_workspace ;;
            3) maybe_fetch_iso_dialog latest "Fetch Latest ISO" ;;
            4) maybe_fetch_iso_dialog configured "Fetch Configured ISO" ;;
            5) dialog_run "Create Disks" create_disks ;;
            6) dialog_run "Install All VMs (Headless)" install_all_headless ;;
            7) dialog_run "Boot All VMs" boot_all ;;
            8) dialog_run "Stop All VMs" stop_all ;;
            9) dialog_run "Network Up" network_up ;;
            10) dialog_run "Network Down" network_down ;;
            11) dialog_run "Autoinstall Scaffold" autoinstall_scaffold ;;
            12) dialog_run "Autoinstall Validate" autoinstall_validate ;;
            13) dialog_run "Clean Disks" clean_disks ;;
            14) dialog_run "Clean All" clean_all ;;
            15) break ;;
        esac
    done

    clear
}

tui() {
    if [[ -t 0 && -t 1 ]] && dialog_bin >/dev/null 2>&1; then
        dialog_menu_loop
    else
        tui_basic
    fi
}

ensure_autoinstall_assistant() {
    if [[ "${USE_DOCKER_AUTOINSTALL}" -eq 1 ]]; then
        require_command docker
        return 0
    fi
    if command -v proxmox-auto-install-assistant >/dev/null 2>&1; then
        return 0
    fi
    if command -v docker >/dev/null 2>&1; then
        log "proxmox-auto-install-assistant not found; falling back to Docker (${DOCKER_AUTOINSTALL_IMAGE})"
        USE_DOCKER_AUTOINSTALL=1
        return 0
    fi
    die "missing required command: proxmox-auto-install-assistant (install it from the Proxmox apt repo, or install Docker for automatic fallback)"
}

docker_autoinstall_run() {
    # Re-runs the given proxmox-lab subcommand inside a Docker container with
    # proxmox-auto-install-assistant installed. Path arguments that start with
    # REPO_ROOT are rewritten to /workspace/... (the container mount point).
    require_command docker
    local -a translated=()
    local arg
    for arg in "$@"; do
        translated+=("${arg//${REPO_ROOT}//workspace}")
    done
    log "running in Docker (${DOCKER_AUTOINSTALL_IMAGE}): ${translated[*]}"
    docker run --rm -i \
        -e HOST_UID="$(id -u)" \
        -e HOST_GID="$(id -g)" \
        -v "${REPO_ROOT}:/workspace" \
        -w /workspace \
        "${DOCKER_AUTOINSTALL_IMAGE}" \
        bash -s -- "${translated[@]}" <<'PROXMOX_LAB_DOCKER'
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive
apt-get update -qq >/dev/null
apt-get install -y -qq wget ca-certificates gnupg xorriso >/dev/null
install -d /usr/share/keyrings
wget -qO /usr/share/keyrings/proxmox-archive-keyring.gpg \
    https://enterprise.proxmox.com/debian/proxmox-archive-keyring-trixie.gpg >/dev/null
printf 'Types: deb\nURIs: http://download.proxmox.com/debian/pve\nSuites: trixie\nComponents: pve-no-subscription\nSigned-By: /usr/share/keyrings/proxmox-archive-keyring.gpg\n' \
    >/etc/apt/sources.list.d/pve-install-repo.sources
apt-get update -qq >/dev/null
apt-get install -y -qq proxmox-auto-install-assistant >/dev/null
./bin/proxmox-lab "$@"
find /workspace/artifacts -user 0 -exec chown "${HOST_UID}:${HOST_GID}" {} + 2>/dev/null || true
PROXMOX_LAB_DOCKER
}

autoinstall_scaffold() {
    ensure_dirs
    local selector="${1:-all}"
    local profile_path="${PROFILE_DIR}/${AUTOINSTALL_PROFILE}.toml"
    local source_template="${TEMPLATE_DIR}/answer.toml.example"
    if [[ -f "${profile_path}" ]]; then
        source_template="${profile_path}"
    fi

    autoinstall_scaffold_one() {
        local index="$1"
        local output fqdn node_ip
        output="$(node_answer_path "${index}")"
        fqdn="$(node_fqdn "${index}")"
        if [[ -f "${output}" ]]; then
            die "${output} already exists"
        fi
        node_ip=""
        if [[ -n "${NODE_FIRST_IP}" ]]; then
            local ip_base ip_last
            ip_base="${NODE_FIRST_IP%.*}"
            ip_last="${NODE_FIRST_IP##*.}"
            node_ip="${ip_base}.$((ip_last + index - 1))"
        fi
        local node_mac node_mac_udev
        node_mac="$(printf '52:54:00:ac:11:%02x' "${index}")"
        node_mac_udev="$(printf 'enx525400ac11%02x' "${index}")"
        sed \
            -e "s/{{FQDN}}/${fqdn}/g" \
            -e "s/{{ROOT_PASSWORD}}/${AUTO_ROOT_PASSWORD}/g" \
            -e "s/{{MAILTO}}/${AUTO_MAILTO}/g" \
            -e "s/{{NODE_IP}}/${node_ip}/g" \
            -e "s/{{NODE_PREFIX_LEN}}/${NODE_PREFIX_LEN}/g" \
            -e "s/{{NODE_GATEWAY}}/${NODE_GATEWAY}/g" \
            -e "s/{{NODE_DNS}}/${NODE_DNS}/g" \
            -e "s/{{NODE_MAC}}/${node_mac}/g" \
            -e "s/{{NODE_MAC_UDEV}}/${node_mac_udev}/g" \
            "${source_template}" > "${output}"
        log "created ${output}"
    }

    if [[ "${selector}" == "all" ]]; then
        local index
        for ((index = 1; index <= NUM_VMS; index++)); do
            autoinstall_scaffold_one "${index}"
        done
    else
        autoinstall_scaffold_one "${selector}"
    fi
}

autoinstall_validate() {
    ensure_autoinstall_assistant
    if [[ "${USE_DOCKER_AUTOINSTALL}" -eq 1 ]]; then
        docker_autoinstall_run autoinstall validate "${1:-all}"
        return
    fi
    local selector="${1:-all}"
    local answer_file index

    if [[ -f "${selector}" ]]; then
        proxmox-auto-install-assistant validate-answer "${selector}"
        return 0
    fi

    if [[ "${selector}" == "all" ]]; then
        for ((index = 1; index <= NUM_VMS; index++)); do
            answer_file="$(node_answer_path "${index}")"
            [[ -f "${answer_file}" ]] || die "missing answer file: ${answer_file}"
            proxmox-auto-install-assistant validate-answer "${answer_file}"
        done
        return 0
    fi

    answer_file="$(node_answer_path "${selector}")"
    [[ -f "${answer_file}" ]] || die "missing answer file: ${answer_file}"
    proxmox-auto-install-assistant validate-answer "${answer_file}"
}

autoinstall_prepare_iso() {
    ensure_dirs
    ensure_autoinstall_assistant

    if [[ "${USE_DOCKER_AUTOINSTALL}" -eq 1 ]]; then
        local src="${1:-}" sel="${2:-all}"
        docker_autoinstall_run autoinstall prepare-iso "$@"
        # Docker creates current.iso with a container-internal path; recreate it on the host.
        if [[ -f "${sel}" ]]; then
            ln -sfn "${ISO_DIR}/$(basename "${src%.iso}")-auto.iso" "$(current_iso_path)"
        elif [[ "${sel}" == "all" ]]; then
            ln -sfn "$(node_iso_path 1)" "$(current_iso_path)"
        fi
        return
    fi

    local source_iso="${1:-}"
    local selector="${2:-all}"
    local answer_file target index

    [[ -n "${source_iso}" ]] || die "source ISO path required"
    [[ -f "${source_iso}" ]] || die "missing source ISO: ${source_iso}"
    [[ "${source_iso}" != *-auto.iso ]] || die "source ISO must be the base Proxmox installer ISO, not an autoinstall ISO"

    if [[ -f "${selector}" ]]; then
        target="${ISO_DIR}/$(basename "${source_iso%.iso}")-auto.iso"
        proxmox-auto-install-assistant prepare-iso "${source_iso}" \
            --fetch-from iso \
            --answer-file "${selector}" \
            --output "${target}"
        ln -sfn "${target}" "$(current_iso_path)"
        log "prepared automated-install ISO ${target}"
        return 0
    fi

    if [[ "${selector}" == "all" ]]; then
        for ((index = 1; index <= NUM_VMS; index++)); do
            answer_file="$(node_answer_path "${index}")"
            target="$(node_iso_path "${index}")"
            [[ -f "${answer_file}" ]] || die "missing answer file: ${answer_file}"
            proxmox-auto-install-assistant prepare-iso "${source_iso}" \
                --fetch-from iso \
                --answer-file "${answer_file}" \
                --output "${target}"
            log "prepared automated-install ISO ${target}"
        done
        ln -sfn "$(node_iso_path 1)" "$(current_iso_path)"
        log "current ISO -> $(node_iso_path 1)"
        return 0
    fi

    answer_file="$(node_answer_path "${selector}")"
    [[ -f "${answer_file}" ]] || die "missing answer file: ${answer_file}"
    target="$(node_iso_path "${selector}")"
    proxmox-auto-install-assistant prepare-iso "${source_iso}" \
        --fetch-from iso \
        --answer-file "${answer_file}" \
        --output "${target}"
    log "prepared automated-install ISO ${target}"
}

cluster_scaffold() {
    ensure_dirs

    local bootstrap_script="${BOOTSTRAP_DIR}/bootstrap-cluster.sh"
    local readme_path="${BOOTSTRAP_DIR}/README.md"
    local first_fqdn
    first_fqdn="$(node_address 1)"

    cat > "${bootstrap_script}" <<EOF
#!/usr/bin/env bash

set -euo pipefail

SSH_USER="\${SSH_USER:-root}"
FIRST_NODE_FQDN="\${FIRST_NODE_FQDN:-${first_fqdn}}"
CLUSTER_NAME="\${CLUSTER_NAME:-${CLUSTER_NAME}}"
DATA_ZPOOL_NAME="\${DATA_ZPOOL_NAME:-${DATA_ZPOOL_NAME}}"
DATA_STORAGE_ID="\${DATA_STORAGE_ID:-${DATA_STORAGE_ID}}"
DATA_STORAGE_CONTENT="\${DATA_STORAGE_CONTENT:-${DATA_STORAGE_CONTENT}}"
DATA_ZPOOL_DEVICES="\${DATA_ZPOOL_DEVICES:-${DATA_ZPOOL_DEVICES}}"
NODE_FQDNS=(
EOF
    local index
    for ((index = 1; index <= NUM_VMS; index++)); do
        printf '  "%s"\n' "$(node_address "${index}")" >> "${bootstrap_script}"
    done
    cat >> "${bootstrap_script}" <<'EOF'
)

ssh_node() {
    local target="$1"
    shift
    ssh -o StrictHostKeyChecking=accept-new "${SSH_USER}@${target}" "$@"
}

configure_data_pool() {
    local target="$1"
    ssh_node "${target}" \
        "DATA_ZPOOL_NAME='${DATA_ZPOOL_NAME}' DATA_STORAGE_ID='${DATA_STORAGE_ID}' DATA_STORAGE_CONTENT='${DATA_STORAGE_CONTENT}' DATA_ZPOOL_DEVICES='${DATA_ZPOOL_DEVICES}' bash -s" <<'REMOTE'
set -euo pipefail
DATA_ZPOOL_NAME="${DATA_ZPOOL_NAME}"
DATA_STORAGE_ID="${DATA_STORAGE_ID}"
DATA_STORAGE_CONTENT="${DATA_STORAGE_CONTENT}"
read -r -a pool_devs <<<"${DATA_ZPOOL_DEVICES}"

if ! zpool list -H -o name "${DATA_ZPOOL_NAME}" >/dev/null 2>&1; then
    # Prefer stable by-id paths (QEMU disks carry b1/b2 suffix in their SCSI ID).
    # Fall back to the raw device names from DATA_ZPOOL_DEVICES when not found.
    b1_dev=$(ls /dev/disk/by-id/scsi-*_b1 2>/dev/null | head -1)
    b2_dev=$(ls /dev/disk/by-id/scsi-*_b2 2>/dev/null | head -1)
    if [[ -n "${b1_dev}" && -n "${b2_dev}" ]]; then
        pool_devs=("${b1_dev}" "${b2_dev}")
    else
        pool_devs=("/dev/${pool_devs[0]}" "/dev/${pool_devs[1]}")
    fi
    zpool create -f "${DATA_ZPOOL_NAME}" mirror "${pool_devs[0]}" "${pool_devs[1]}"
fi

if ! pvesm status --storage "${DATA_STORAGE_ID}" >/dev/null 2>&1; then
    pvesm add zfspool "${DATA_STORAGE_ID}" -pool "${DATA_ZPOOL_NAME}" -content "${DATA_STORAGE_CONTENT}"
fi
REMOTE
}

setup_node_ssh_keys() {
    local pub_key
    for node in "${NODE_FQDNS[@]}"; do
        [[ "${node}" == "${FIRST_NODE_FQDN}" ]] && continue
        ssh_node "${node}" \
            "test -f /root/.ssh/id_ed25519.pub || ssh-keygen -t ed25519 -N '' -f /root/.ssh/id_ed25519 -q"
        pub_key="$(ssh_node "${node}" "cat /root/.ssh/id_ed25519.pub")"
        printf '%s\n' "${pub_key}" | ssh_node "${FIRST_NODE_FQDN}" \
            "mkdir -p /root/.ssh && chmod 700 /root/.ssh && cat >> /root/.ssh/authorized_keys"
        ssh_node "${node}" \
            "ssh-keyscan -H '${FIRST_NODE_FQDN}' 2>/dev/null >> /root/.ssh/known_hosts"
    done
}

create_cluster() {
    ssh_node "${FIRST_NODE_FQDN}" "pvecm status >/dev/null 2>&1 || pvecm create \"${CLUSTER_NAME}\""
}

join_cluster() {
    local target="$1"
    ssh_node "${target}" "pvecm status >/dev/null 2>&1 || pvecm add \"${FIRST_NODE_FQDN}\" -use_ssh 1"
}

main() {
    setup_node_ssh_keys
    create_cluster

    local node
    for node in "${NODE_FQDNS[@]}"; do
        configure_data_pool "${node}"
    done

    local index
    for ((index = 1; index < ${#NODE_FQDNS[@]}; index++)); do
        join_cluster "${NODE_FQDNS[index]}"
    done
}

main "$@"
EOF
    chmod +x "${bootstrap_script}"

    cat > "${readme_path}" <<EOF
# Cluster bootstrap

Generated by \`proxmox-lab cluster scaffold\`.

This directory contains a host-side helper script for the second phase of the lab:

- create the Proxmox cluster on node 1
- join nodes 2..${NUM_VMS}
- create \`${DATA_ZPOOL_NAME}\` from \`${DATA_ZPOOL_DEVICES}\` on every node
- register that pool in Proxmox storage as \`${DATA_STORAGE_ID}\`

Expected prerequisites:

- unattended install completed on all nodes
- nodes reachable over SSH as \`root@\$(node_fqdn N)\`
- host can resolve node FQDNs

Run:

\`\`\`bash
${bootstrap_script}
\`\`\`
EOF

    log "created ${bootstrap_script}"
    log "created ${readme_path}"
}

# ── Wizard helpers ────────────────────────────────────────────────────────────

_W_BOLD=$'\033[1m'
_W_RESET=$'\033[0m'
_W_GREEN=$'\033[0;32m'
_W_YELLOW=$'\033[1;33m'
_W_CYAN=$'\033[0;36m'
_W_RED=$'\033[0;31m'
_W_STEP=0

_wiz_sep() {
    printf '%s  ────────────────────────────────────────────────────%s\n' "${_W_CYAN}" "${_W_RESET}"
}

_wiz_step() {
    _W_STEP=$((_W_STEP + 1))
    _wiz_sep
    printf '%s  Passo %d — %s%s\n' "${_W_BOLD}${_W_CYAN}" "${_W_STEP}" "$1" "${_W_RESET}"
    _wiz_sep
    [[ -n "${2:-}" ]] && printf '  %b\n' "$2"
}

_wiz_pause() {
    printf '\n%s  → Premi INVIO per continuare, Ctrl+C per annullare... %s' "${_W_YELLOW}" "${_W_RESET}"
    read -r
    printf '\n'
}

_wiz_run() {
    # _wiz_run <label> <display_cmd> <actual_cmd...>
    local label="$1" display_cmd="$2"; shift 2
    printf '  %s▶  %s%s\n' "${_W_BOLD}" "${label}" "${_W_RESET}"
    printf '     %s$ %s%s\n' "${_W_CYAN}" "${display_cmd}" "${_W_RESET}"
    if "$@"; then
        printf '  %s✓  OK%s\n' "${_W_GREEN}" "${_W_RESET}"
    else
        local rc=$?
        printf '  %s✗  Errore (rc=%d)%s\n' "${_W_RED}" "${rc}" "${_W_RESET}"
        die "wizard interrotto: ${label}"
    fi
}

_wiz_info() { printf '  %s·  %s%s\n' "${_W_CYAN}"   "$*" "${_W_RESET}"; }
_wiz_ok()   { printf '  %s✓  %s%s\n' "${_W_GREEN}"  "$*" "${_W_RESET}"; }
_wiz_warn() { printf '  %s⚠  %s%s\n' "${_W_YELLOW}" "$*" "${_W_RESET}"; }

_wiz_wait_ssh() {
    local target="$1"
    local attempts=0
    printf '    attendo SSH su %s ' "${target}"
    while ! (: >/dev/tcp/"${target}"/22) 2>/dev/null; do
        printf '.'
        sleep 5
        attempts=$((attempts + 1))
        if [[ "${attempts}" -gt 72 ]]; then
            printf ' timeout\n'
            warn "SSH su ${target} non disponibile dopo 6 minuti — verifica il boot con: make vm-serial"
            return 1
        fi
    done
    printf ' %s✓%s\n' "${_W_GREEN}" "${_W_RESET}"
}

wizard() {
    _W_STEP=0
    local self
    self="$(readlink -f "${BASH_SOURCE[0]}")"

    # ── Banner ────────────────────────────────────────────────────────────────
    printf '\n%s' "${_W_BOLD}${_W_CYAN}"
    printf '╔══════════════════════════════════════════════════════╗\n'
    printf '║   Proxmox VE Lab — Setup Wizard                     ║\n'
    printf '╚══════════════════════════════════════════════════════╝\n'
    printf '%s\n' "${_W_RESET}"
    printf 'Questo wizard ti guida nella creazione di un cluster Proxmox VE\n'
    printf 'a %d nodi su QEMU/KVM con root ZFS mirror e pool VM ZFS.\n\n' "${NUM_VMS}"
    printf 'Configurazione attiva (%s):\n' "${CONFIG_FILE}"
    _wiz_info "Nodi:             ${NUM_VMS}  (${VM_PREFIX}1 … ${VM_PREFIX}${NUM_VMS})"
    _wiz_info "Profilo:          ${AUTOINSTALL_PROFILE}"
    _wiz_info "Accel:            ${VM_ACCEL}  RAM: ${VM_MEMORY_MB} MB  CPU: ${VM_CORES} core"
    if [[ "${USE_TAP_NETWORK}" == "1" ]]; then
        _wiz_info "Rete:             TAP bridge ${BRIDGE_NAME}  (${BRIDGE_ADDRESS:-IP non impostato})"
        if [[ -n "${NODE_FIRST_IP}" ]]; then
            _wiz_info "IP nodi:          ${NODE_FIRST_IP} … +$((NUM_VMS - 1))"
        fi
    else
        _wiz_info "Rete:             user-mode QEMU NAT"
    fi
    _wiz_info "Cluster:          ${CLUSTER_NAME}"
    _wiz_info "Root password:    ${AUTO_ROOT_PASSWORD}"
    _wiz_info "Proxmox ISO:      ${PROXMOX_ISO_VERSION}"
    printf '\n'

    if [[ "${AUTO_ROOT_PASSWORD}" == "CHANGEME" ]]; then
        _wiz_warn "AUTO_ROOT_PASSWORD è ancora 'CHANGEME' — imposta una password sicura in config.env"
        die "modifica AUTO_ROOT_PASSWORD in config.env prima di eseguire il wizard"
    fi

    _wiz_pause

    # ── 1. Prerequisiti ───────────────────────────────────────────────────────
    _wiz_step "Prerequisiti" \
        "Verifico che gli strumenti necessari siano presenti sull'host."
    local prereq_ok=1
    for _cmd in "${QEMU_BIN}" "${QEMU_IMG_BIN}"; do
        if command -v "${_cmd}" >/dev/null 2>&1; then
            _wiz_ok "${_cmd}"
        else
            _wiz_warn "${_cmd} non trovato — installa qemu-system-x86"
            prereq_ok=0
        fi
    done
    if [[ "${USE_TAP_NETWORK}" == "1" ]]; then
        if command -v ip >/dev/null 2>&1; then
            _wiz_ok "iproute2 (ip)"
        else
            _wiz_warn "ip non trovato — installa iproute2"
            prereq_ok=0
        fi
    fi
    if command -v proxmox-auto-install-assistant >/dev/null 2>&1; then
        _wiz_ok "proxmox-auto-install-assistant"
    elif command -v docker >/dev/null 2>&1; then
        _wiz_ok "docker  (usato come fallback per proxmox-auto-install-assistant)"
    else
        _wiz_warn "né proxmox-auto-install-assistant né docker trovati"
        prereq_ok=0
    fi
    [[ "${prereq_ok}" == "1" ]] || die "installa i prerequisiti mancanti e riprova"

    # ── 2. Pulizia ────────────────────────────────────────────────────────────
    _wiz_step "Pulizia artefatti esistenti" \
        "Rimuovo dischi, log, pid file e ISO per-nodo precedenti.\n  L'ISO base scaricato viene mantenuto."
    _wiz_pause
    _wiz_run "clean all" "make clean-all" clean_all

    # ── 3. Init ───────────────────────────────────────────────────────────────
    _wiz_step "Inizializzazione directory" \
        "Creo le directory artifacts/ necessarie."
    _wiz_run "init" "make init" init_workspace

    # ── 4. ISO ────────────────────────────────────────────────────────────────
    local iso_path
    iso_path="$(configured_iso_path)"
    _wiz_step "ISO Proxmox VE ${PROXMOX_ISO_VERSION}" \
        "L'ISO base viene scaricato una sola volta e riutilizzato per tutti i nodi.\n  Destinazione: ${iso_path}"
    if [[ -f "${iso_path}" ]]; then
        _wiz_ok "ISO già presente, salto il download"
    else
        _wiz_pause
        _wiz_run "scarico ISO ${PROXMOX_ISO_VERSION}" "make iso-configured" iso_fetch configured
    fi

    # ── 5. Autoinstall ISOs ───────────────────────────────────────────────────
    _wiz_step "Generazione ISO unattended per ogni nodo" \
        "Per ogni nodo creo un file di risposta TOML con hostname, IP statico, password\n  e layout disco, poi lo incorporo in una copia dell'ISO base.\n  Risultato: artifacts/iso/pve0N-auto.iso"
    _wiz_pause
    _wiz_run "autoinstall scaffold" "make autoinstall-scaffold" autoinstall_scaffold all
    _wiz_run "autoinstall prepare-iso" "make autoinstall-prepare" autoinstall_prepare_iso "${iso_path}" all

    # ── 6. Rete TAP ───────────────────────────────────────────────────────────
    if [[ "${USE_TAP_NETWORK}" == "1" ]]; then
        local subnet="${NODE_FIRST_IP%.*}.0/${NODE_PREFIX_LEN}"
        _wiz_step "Rete TAP/bridge — richiede sudo" \
            "Creo il bridge ${BRIDGE_NAME} con IP ${BRIDGE_ADDRESS:-<BRIDGE_ADDRESS non impostato>}\n  e i TAP ${TAP_PREFIX}1…${TAP_PREFIX}${NUM_VMS}.\n\n  IMPORTANTE — NAT per accesso internet durante l'install:\n    sudo sysctl -w net.ipv4.ip_forward=1\n    sudo iptables -t nat -A POSTROUTING -s ${subnet} -o \$(ip route get 8.8.8.8 | awk '/dev/{print \$5; exit}') -j MASQUERADE\n  Senza NAT l'install funziona ma potrebbe rallentare su timeout NTP/DNS."
        _wiz_pause
        _wiz_run "network up" "sudo make network-up" \
            sudo "${self}" --config "${CONFIG_FILE}" --set USE_TAP_NETWORK=1 network up
        printf '\n'
        _wiz_warn "Ricorda di aggiungere le regole NAT sopra se vuoi accesso internet durante l'install."
        printf '\n  %s→ Premi INVIO quando sei pronto (o subito se hai già il NAT attivo)... %s' "${_W_YELLOW}" "${_W_RESET}"
        read -r
        printf '\n'
    fi

    # ── 7. Dischi ─────────────────────────────────────────────────────────────
    _wiz_step "Creazione dischi VM" \
        "Per ogni nodo creo 4 dischi qcow2 in artifacts/disks/:\n  · a1 + a2  (20 GB ciascuno) → sda + sdb  — root ZFS mirror (rpool)\n  · b1 + b2  (40 GB ciascuno) → sdc + sdd  — pool VM ZFS (${DATA_ZPOOL_NAME})"
    _wiz_pause
    _wiz_run "vm create" "make create" create_disks

    # ── 8. Install ────────────────────────────────────────────────────────────
    _wiz_step "Installazione unattended (sequenziale)" \
        "Ogni VM si avvia dall'ISO unattended e installa Proxmox su ZFS mirror.\n  QEMU esce automaticamente al riavvio che segnala il termine dell'install.\n  Durata stimata: 15–30 minuti per nodo (dipende da I/O e CPU).\n\n  Monitora il progresso in un altro terminale:\n    watch -n 10 'ls -lh artifacts/disks/pve0*a1.qcow2'"
    _wiz_pause
    _wiz_run "install serial" "make install-serial" install_all_headless_serial

    # ── 9. Boot ───────────────────────────────────────────────────────────────
    _wiz_step "Boot dei nodi installati" \
        "I nodi si avviano dal disco in modalità headless (background).\n  Il log seriale è in artifacts/logs/pve0N-serial.log.\n  Aspetto che SSH sia disponibile su tutti i nodi prima di continuare."
    _wiz_pause
    _wiz_run "boot headless" "make boot-headless" boot_all_headless
    printf '\n'
    local idx
    for ((idx = 1; idx <= NUM_VMS; idx++)); do
        _wiz_wait_ssh "$(node_address "${idx}")"
    done

    # ── 10. SSH host→nodi ─────────────────────────────────────────────────────
    _wiz_step "Configurazione accesso SSH host → nodi" \
        "Il bootstrap ha bisogno di SSH passwordless dall'host verso i nodi.\n  Userò ssh-copy-id per copiare la chiave pubblica dell'host su ogni nodo.\n  Ti verrà chiesta la password root (${AUTO_ROOT_PASSWORD}) una volta per nodo."
    _wiz_pause
    if [[ ! -f "${HOME}/.ssh/id_ed25519.pub" && ! -f "${HOME}/.ssh/id_rsa.pub" ]]; then
        _wiz_run "genera chiave SSH host" \
            "ssh-keygen -t ed25519 -N '' -f ~/.ssh/id_ed25519" \
            ssh-keygen -t ed25519 -N '' -f "${HOME}/.ssh/id_ed25519" -q
    fi
    for ((idx = 1; idx <= NUM_VMS; idx++)); do
        local node_addr
        node_addr="$(node_address "${idx}")"
        _wiz_run "copia chiave SSH su nodo ${idx}" \
            "ssh-copy-id root@${node_addr}" \
            ssh-copy-id -o StrictHostKeyChecking=accept-new "root@${node_addr}"
    done

    # ── 11. Bootstrap cluster ─────────────────────────────────────────────────
    _wiz_step "Bootstrap cluster" \
        "Genero il bootstrap script ed eseguo automaticamente:\n  1. Scambio chiavi SSH tra i nodi (per pvecm add -use_ssh 1)\n  2. pvecm create ${CLUSTER_NAME}  su pve01\n  3. zpool create ${DATA_ZPOOL_NAME}  su ogni nodo (con percorsi by-id stabili)\n  4. Registrazione storage vmdata in Proxmox\n  5. pvecm add  su pve02…pve0${NUM_VMS}"
    _wiz_pause
    _wiz_run "cluster scaffold" "make cluster-scaffold" cluster_scaffold
    _wiz_run "bootstrap cluster" "bash artifacts/bootstrap/bootstrap-cluster.sh" \
        bash "${BOOTSTRAP_DIR}/bootstrap-cluster.sh"

    # ── Completato ────────────────────────────────────────────────────────────
    printf '\n%s' "${_W_BOLD}${_W_GREEN}"
    printf '╔══════════════════════════════════════════════════════╗\n'
    printf '║   ✓  Lab Proxmox VE pronto!                         ║\n'
    printf '╚══════════════════════════════════════════════════════╝\n'
    printf '%s\n' "${_W_RESET}"
    printf 'Accedi alla UI web:\n\n'
    for ((idx = 1; idx <= NUM_VMS; idx++)); do
        printf '  %sNodo %d%s  https://%s:8006\n' \
            "${_W_BOLD}" "${idx}" "${_W_RESET}" "$(node_address "${idx}")"
    done
    printf '\n'
    printf '  Utente:    %sroot%s\n'     "${_W_BOLD}" "${_W_RESET}"
    printf '  Password:  %s%s%s\n\n'    "${_W_BOLD}" "${AUTO_ROOT_PASSWORD}" "${_W_RESET}"
    printf 'Verifica cluster:\n'
    printf '  ssh root@%s pvecm status\n'  "$(node_address 1)"
    printf '  ssh root@%s zpool list\n'    "$(node_address 1)"
    printf '  ssh root@%s pvesm status\n\n' "$(node_address 1)"
    printf 'Per spegnere il lab:\n'
    printf '  make stop\n'
    [[ "${USE_TAP_NETWORK}" == "1" ]] && printf '  sudo make network-down\n'
    printf '\n'
}

menu() {
    PS3='Select action: '
    select action in \
        "status" \
        "init" \
        "iso fetch latest" \
        "vm create" \
        "vm install-headless" \
        "vm boot" \
        "vm stop" \
        "clean disks" \
        "clean all" \
        "network up" \
        "network down" \
                "cluster scaffold" \
                "quit"; do
        case "${action}" in
            "status") status ;;
            "init") init_workspace ;;
            "iso fetch latest") iso_fetch latest ;;
            "vm create") create_disks ;;
            "vm install-headless") install_all_headless ;;
            "vm boot") boot_all ;;
            "vm stop") stop_all ;;
            "clean disks") clean_disks ;;
            "clean all") clean_all ;;
            "network up") network_up ;;
            "network down") network_down ;;
            "cluster scaffold") cluster_scaffold ;;
            "quit") break ;;
            *) warn "invalid choice" ;;
        esac
    done
}

start_all() {
    boot_all
}

install_all_headless() {
    local index
    for ((index = 1; index <= NUM_VMS; index++)); do
        install_vm_headless "${index}"
    done
}

wait_for_install() {
    local index="$1"
    local vm pid_file pid
    vm="$(vm_name "${index}")"
    pid_file="$(vm_pid_path "${index}")"
    local pid
    pid="$(cat "${pid_file}" 2>/dev/null || true)"
    [[ -n "${pid}" ]] || { warn "${vm}: no pid file, skipping wait"; return 0; }
    log "waiting for ${vm} install to complete (pid ${pid})..."
    while kill -0 "${pid}" 2>/dev/null; do
        sleep 5
    done
    log "${vm} install complete"
}

install_vm_headless_serial() {
    local index="$1"
    install_vm_headless "${index}"
    wait_for_install "${index}"
}

install_all_headless_serial() {
    local index
    for ((index = 1; index <= NUM_VMS; index++)); do
        install_vm_headless_serial "${index}"
    done
}

boot_all() {
    local index
    for ((index = 1; index <= NUM_VMS; index++)); do
        boot_vm "${index}"
    done
}

boot_all_headless() {
    local index
    for ((index = 1; index <= NUM_VMS; index++)); do
        boot_vm_headless "${index}"
    done
}

stop_all() {
    local index
    for ((index = 1; index <= NUM_VMS; index++)); do
        stop_vm "${index}"
    done
}

parse_global_options() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config)
                CONFIG_FILE="$2"
                shift 2
                ;;
            --set)
                CONFIG_OVERRIDES+=("$2")
                shift 2
                ;;
            --docker)
                USE_DOCKER_AUTOINSTALL=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                break
                ;;
        esac
    done

    REMAINING_ARGS=("$@")
}

main() {
    parse_global_options "$@"
    load_config

    set -- "${REMAINING_ARGS[@]:-}"
    local command="${1:-menu}"
    shift || true

    case "${command}" in
        menu) menu ;;
        tui) tui ;;
        wizard) wizard ;;
        init) init_workspace ;;
        status) status ;;
        iso)
            case "${1:-}" in
                fetch) shift; iso_fetch "${1:-latest}" ;;
                current) iso_current ;;
                configured-path) configured_iso_path ;;
                *) die "usage: proxmox-lab iso fetch [latest|VERSION|URL] | current | configured-path" ;;
            esac
            ;;
        network)
            case "${1:-}" in
                up) network_up ;;
                down) network_down ;;
                status) network_status ;;
                *) die "usage: proxmox-lab network up|down|status" ;;
            esac
            ;;
        vm)
            case "${1:-}" in
                create) create_disks ;;
                install-headless)
                    case "${2:-all}" in
                        all) install_all_headless ;;
                        *) install_vm_headless "${2}" ;;
                    esac
                    ;;
                install-headless-serial)
                    case "${2:-all}" in
                        all) install_all_headless_serial ;;
                        *) install_vm_headless_serial "${2}" ;;
                    esac
                    ;;
                boot)
                    case "${2:-all}" in
                        all) boot_all ;;
                        *) boot_vm "${2}" ;;
                    esac
                    ;;
                boot-headless)
                    case "${2:-all}" in
                        all) boot_all_headless ;;
                        *) boot_vm_headless "${2}" ;;
                    esac
                    ;;
                start)
                    case "${2:-all}" in
                        all) boot_all ;;
                        *) boot_vm "${2}" ;;
                    esac
                    ;;
                start-headless)
                    case "${2:-all}" in
                        all) boot_all_headless ;;
                        *) boot_vm_headless "${2}" ;;
                    esac
                    ;;
                stop)
                    case "${2:-all}" in
                        all) stop_all ;;
                        *) stop_vm "${2}" ;;
                    esac
                    ;;
                inspect)
                    case "${2:-all}" in
                        all)
                            local index
                            for ((index = 1; index <= NUM_VMS; index++)); do
                                inspect_vm "${index}"
                                printf '\n'
                            done
                            ;;
                        *) inspect_vm "${2}" ;;
                    esac
                    ;;
                serial) serial_vm "${2:-1}" ;;
                *) die "usage: proxmox-lab vm create|install-headless [all|INDEX]|boot [all|INDEX]|boot-headless [all|INDEX]|start [all|INDEX]|start-headless [all|INDEX]|stop [all|INDEX]|inspect [all|INDEX]|serial [INDEX]" ;;
            esac
            ;;
        clean)
            case "${1:-}" in
                disks) clean_disks ;;
                logs) clean_logs ;;
                run) clean_run ;;
                autoinstall) clean_autoinstall ;;
                all) clean_all ;;
                *) die "usage: proxmox-lab clean disks|logs|run|autoinstall|all" ;;
            esac
            ;;
        autoinstall)
            case "${1:-}" in
                scaffold) shift; autoinstall_scaffold "${1:-all}" ;;
                validate) shift; autoinstall_validate "${1:-}" ;;
                prepare-iso) shift; autoinstall_prepare_iso "${1:-}" "${2:-}" ;;
                *) die "usage: proxmox-lab autoinstall scaffold [all|INDEX]|validate [all|INDEX|ANSWER_FILE]|prepare-iso SOURCE_ISO [all|INDEX|ANSWER_FILE]" ;;
            esac
            ;;
        cluster)
            case "${1:-}" in
                scaffold) cluster_scaffold ;;
                *) die "usage: proxmox-lab cluster scaffold" ;;
            esac
            ;;
        *)
            usage
            exit 1
            ;;
    esac
}

main "$@"
